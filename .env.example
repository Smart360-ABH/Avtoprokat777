# Application Settings
PORT=3000
NODE_ENV=development

# Database Connection (PostgreSQL)
# For Render: Obtain from the Render Dashboard after creating a database
# Example: postgres://user:password@hostname:port/database
DATABASE_URL=postgres://user:password@localhost:5432/autopro777

# Frontend: When developing or deploying separately, set the frontend API base URL.
# Example for local dev when backend runs on http://localhost:3000:
# VITE_API_URL=http://localhost:3000
